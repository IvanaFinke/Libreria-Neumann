@page "/mi-carrito"
@implements IDisposable
@rendermode InteractiveServer

<!-- Componente para el diseño del carrito en PC -->

@if(MostrarCarritoPC)
{
    <div class="carrito-full-screen">

        <h1 class="titulo-carrito">Mi carrito</h1>
        <div class="lista-libros-carrito">


            @foreach(var item in carritoService!.Items)
            {
                <div class="datos-libro-carrito">
                    <img src="@item.libro.ImageURL" />

                    <div class="titulo-precio">
                        <div class="titulo-repetido">
                            <h4 class="titulo-libro-carrito">@item.libro.Titulo</h4>
                            @if (item.Cantidad > 1)
                            {
                                <h4 class="contador">(@item.Cantidad)</h4>
                            }
                        </div>
                       
                        <h4 class="precio-carrito">$@(item.libro.Precio * item.Cantidad)</h4>
                    </div>

                    <button class="boton-basura-carrito" @onclick="() => EliminarLibro(item.libro)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            }

        </div>

        <div class="seccion-compra-botones">

            <div class="total-clase">
                <h4 class="frase-total">Total:</h4>
                <h4 class="frase-precio-total">$@carritoService?.Total</h4>
            </div>

            <br />

         <button class="boton-comprar">
          <span><strong>COMPRAR</strong></span>
          </button>
        </div>

    </div>
}


@if (MostrarCarritoDetallesPago)
{
    <div class="carrito-detalles-pago">
        <div class="carrito">

            <h3 class="titulo-carrito">Mi carrito</h3>
            <div class="lista-libros-carrito">

                @foreach(var libro in libros)
                {
                    <div class="datos-libro-carrito">
                        <img src="https://i.postimg.cc/9MJy1Jrj/fantasm-ope.jpg" />

                        <div class="titulo-precio">
                            <h4 class="titulo-libro-carrito">EL FANTASMA DE LA OPERA</h4>
                            <h4 class="precio-carrito">$20.0000</h4>
                        </div>

                        <button class="boton-basura-carrito">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                }
                
               
            </div>

            <div class="seccion-compra-botones">

                <div class="total-clase">
                    <h4 class="frase-total">Total:</h4>
                    <h4 class="frase-precio-total">$124.000</h4>
                </div>

                <br />
            </div>
        </div>
    </div>
}
   

@code{
    [Parameter] public bool MostrarCarritoDetallesPago { get; set; } = false;
    [Parameter] public bool MostrarCarritoPC { get; set; } = true;
    [Inject] LibroService? libroService { get; set; }
    [Inject] CarritoService? carritoService { get; set; }
    private List<Libro>? libros;
    private string? titulo, autor, descripcion, editorial, imagen = "";
    private decimal precio;
    private int fechaPublicaciom, cantPags,contadorLibro;

    protected override void OnInitialized()
    {
        carritoService!.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        carritoService!.OnChange -= StateHasChanged;
    }

    private void EliminarLibro(Libro libro)
    {
        carritoService!.EliminarLibro(libro);
    }

    public void AgregarLibroAlCarrito(Libro libro)
    {
            libros?.Add(libro);
    }

}